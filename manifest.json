{
  "manifest_version": 3,
  "name": "Ryuko Auto Share",
  "description": "Boost your shares on facebook!",
  "version": "1.0",
  "permissions": [
    "storage",
    "cookies",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://*.facebook.com/",
    "https://business.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
